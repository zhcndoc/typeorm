{
  "$schema": "https://json.schemastore.org/mocharc",
  "check-leaks": true,
  "color": true,
  "exit": true,
  "file": ["./build/compiled/test/utils/test-setup.js"],
  // mongodb@7.2+ leaks `allowedDriverRequire` on globalThis; allowlist it.
  "globals": ["allowedDriverRequire"],
  "recursive": true,
  "spec": ["./build/compiled/test/**/*.test.{js,ts}"],
  "timeout": 90000
}
